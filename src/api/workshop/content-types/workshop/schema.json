{
  "kind": "collectionType",
  "collectionName": "workshops",
  "info": {
    "singularName": "workshop",
    "pluralName": "workshops",
    "displayName": "workshop"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "content": {
      "type": "richtext"
    },
    "shortDescription": {
      "type": "string"
    },
    "workshopDate": {
      "type": "date"
    },
    "location": {
      "type": "string"
    },
    "registraionLink": {
      "type": "string"
    },
    "level": {
      "type": "enumeration",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "duration": {
      "type": "string"
    },
    "enrolled": {
      "type": "string"
    },
    "seats": {
      "type": "string"
    },
    "tags": {
      "type": "json"
    },
    "curriculum": {
      "type": "json"
    },
    "requirements": {
      "type": "json"
    },
    "instructor_name": {
      "type": "string"
    },
    "instructor_title": {
      "type": "string"
    },
    "instructor_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
